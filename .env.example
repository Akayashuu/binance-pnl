# Postgres
POSTGRES_USER=binancetracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=binancetracker
POSTGRES_PORT=5432

# Backend
HTTP_PORT=8080
DATABASE_URL=postgres://binancetracker:changeme@postgres:5432/binancetracker?sslmode=disable
LOG_LEVEL=info

# 32-byte AES key encoded as base64 — used to encrypt Binance API secrets at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Optional: bootstrap Binance credentials (otherwise set them via the Settings UI)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Price refresh cadence (Go duration syntax)
PRICE_REFRESH_INTERVAL=60s

# Quote currency used for valuation (must be a Binance quote, e.g. USDT, BUSD, EUR)
QUOTE_CURRENCY=USDT

# Comma-separated list of base assets to sync trades for. Binance requires a
# symbol on the GetMyTrades endpoint, so we iterate per pair {ASSET}{QUOTE}.
TRACKED_ASSETS=BTC,ETH,SOL,BNB

# Quote currencies to fetch trades for. Pairs are fetched for each base × quote
# combination (e.g. BTCUSDT, BTCUSDC, ETHUSDT, ETHUSDC…). The primary
# QUOTE_CURRENCY is always included even if omitted here.
ACCEPTED_QUOTES=USDT,USDC

# Frontend
FRONTEND_PORT=5173
PUBLIC_API_BASE_URL=http://localhost:8080
